<Page x:Class="NewScarAnime.SearchStatus"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:NewScarAnime"
      mc:Ignorable="d" 
      d:DesignHeight="768" d:DesignWidth="1366"
      Title="SearchStatus">

    <Grid>
        <StackPanel>
            <ui:TextBlock x:Name="StatusText" Text="添加中，请稍候..." 
           FontSize="32" 
           FontWeight="Bold" 
           Margin="0,10,0,10"
           HorizontalAlignment="Center" 
           VerticalAlignment="Top"
           Foreground="#FFB6C1">
                <ui:TextBlock.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1"/>
                </ui:TextBlock.Effect>
            </ui:TextBlock>

            <ProgressBar x:Name="Status" IsIndeterminate="True" VerticalAlignment="Top" Foreground="#FFB6C1"/>
    </StackPanel>

        

    </Grid>
</Page>
