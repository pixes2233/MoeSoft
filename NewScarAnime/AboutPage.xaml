<Page x:Class="NewScarAnime.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:NewScarAnime"
      mc:Ignorable="d" 
      d:DesignHeight="768" d:DesignWidth="1366"
      Title="AboutPage">

    <!-- 统一资源：保持原主题，增强层次与细节 -->
    <Page.Resources>
        <LinearGradientBrush x:Key="PageBackground" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFFAFBFF" Offset="0.0"/>
            <GradientStop Color="#FFEFF3F7" Offset="1.0"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="CardBackground" Color="#80FFFFFF"/>
        <SolidColorBrush x:Key="PrimaryText" Color="#1B1B1B"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#555555"/>
        <SolidColorBrush x:Key="Accent" Color="#FF6AA9FF"/>

        <DropShadowEffect x:Key="SoftShadow" Color="#000000" BlurRadius="12" ShadowDepth="2" Opacity="0.14"/>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryText}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="22"/>
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 中央内容容器 -->
                <StackPanel Grid.Column="1" Width="720" HorizontalAlignment="Center">

                    <!-- 顶部标题区 -->
                    <Border CornerRadius="20" Padding="22" Margin="0,0,0,22"
                            Background="{StaticResource CardBackground}"
                            Effect="{StaticResource SoftShadow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- App 图标 -->
                            <Border Width="92" Height="92" CornerRadius="18"
                                    Background="#14000000" Grid.Column="0">
                                <Image Source="/Icon/icon.png" Stretch="Uniform" Margin="12"/>
                            </Border>

                            <!-- 标题文字 -->
                            <StackPanel Grid.Column="1" Margin="20,4,0,0">
                                <TextBlock Text="About MoeSoft"
                                           FontSize="40"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryText}"/>
                                <TextBlock Text="A modern anime tracker designed to organize your shows and make your viewing experience more convenient."
                                           Style="{StaticResource BodyText}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 基本信息卡片 -->
                    <Border Background="{StaticResource CardBackground}" CornerRadius="14"
                            Padding="22" Margin="0,0,0,18"
                            Effect="{StaticResource SoftShadow}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="Version" Style="{StaticResource SectionHeader}"/>
                                <TextBlock Text="1.4.4 Beta" Style="{StaticResource BodyText}"/>
                            </StackPanel>

                            <Separator Grid.Row="1" Margin="0,6" Opacity="0.15"/>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Author" Style="{StaticResource SectionHeader}"/>
                                    <TextBlock Text="RADAMU" Style="{StaticResource BodyText}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Target Framework" Style="{StaticResource SectionHeader}"/>
                                    <TextBlock Text=".NET 8.0 (Windows x64)" Style="{StaticResource BodyText}"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- 开源组件卡片 -->
                    <Border Background="{StaticResource CardBackground}" CornerRadius="14"
                            Padding="22"
                            Effect="{StaticResource SoftShadow}">
                        <StackPanel>
                            <TextBlock Text="Open Source Credits" Style="{StaticResource SectionHeader}" Margin="0,0,0,14"/>

                            <ItemsControl>
                                <ItemsControl.Items>
                                    <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">Newtonsoft.Json © James Newton-King — MIT License</sys:String>
                                    <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">WPF-UI © lepoco — MIT License</sys:String>
                                    <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">WPF-UI.Abstractions © lepoco — MIT License</sys:String>
                                    <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">Microsoft-WindowsAPICodePack-Core — Ms-PL</sys:String>
                                    <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">Microsoft-WindowsAPICodePack-Shell — Ms-PL</sys:String>
                                </ItemsControl.Items>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,6,0,0">
                                            <Ellipse Width="6" Height="6" Fill="{StaticResource Accent}" Margin="0,8,10,0"/>
                                            <TextBlock Text="{Binding}" Style="{StaticResource BodyText}"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>