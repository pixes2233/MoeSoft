<Page x:Class="NewScarAnime.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      xmlns:local="clr-namespace:NewScarAnime"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="AboutPage">

    <Page.Resources>
        <!-- 基础色彩 -->
        <SolidColorBrush x:Key="CardBackground" Color="#0FFFFFFF"/>
        <!-- 稍微降低不透明度，增强通透感 -->
        <SolidColorBrush x:Key="CardBorderBrush" Color="#1FFFFFFF"/>
        <!-- 新增：极细边框颜色 -->
        <SolidColorBrush x:Key="PrimaryText" Color="#F2F2F2"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#C6C6C6"/>
        <SolidColorBrush x:Key="Accent" Color="#FF6AA9FF"/>
        <SolidColorBrush x:Key="SubtleFill" Color="#08FFFFFF"/>

        <!-- 样式：卡片容器 -->
        <Style x:Key="ModernCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <!-- 稍微减小圆角，显得更现代硬朗 -->
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <!-- 样式：小标题 -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="Opacity" Value="0.9"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- 样式：正文内容 -->
        <Style x:Key="ContentText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryText}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Background="Transparent">
        <ui:DynamicScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,20">
            <StackPanel Width="680" HorizontalAlignment="Center">

                <!-- 1. 品牌头部区域 (居中布局更具现代感) -->
                <StackPanel Margin="0,40,0,50" HorizontalAlignment="Center">
                    <Border Width="100" Height="100" CornerRadius="24" Background="{StaticResource SubtleFill}" Margin="0,0,0,24">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Opacity="0.15"/>
                        </Border.Effect>
                        <Image Source="/Icon/icon.png" Stretch="Uniform" Margin="10"/>
                    </Border>

                    <TextBlock Text="MoeSoft" 
                               FontSize="36" FontWeight="Bold" 
                               Foreground="{StaticResource PrimaryText}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>

                    <TextBlock Text="让追番体验回归纯粹与便捷" 
                               FontSize="16" Foreground="{StaticResource SecondaryText}"
                               HorizontalAlignment="Center" Opacity="0.8"/>
                </StackPanel>

                <!-- 2. 信息概览 (使用网格布局代替列表) -->
                <Border Style="{StaticResource ModernCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <!-- 分割线 -->
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左侧：版本信息 -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Current Version" Style="{StaticResource SectionTitle}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="v1.5.2" 
                                           FontSize="24" FontWeight="Light" 
                                           Foreground="{StaticResource PrimaryText}"
                                           VerticalAlignment="Center"/>
                                <!-- 版本标签 Badge -->
                                <Border Background="{StaticResource Accent}" CornerRadius="4" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="BETA" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- 中间分割线 -->
                        <Rectangle Grid.Column="1" Width="1" Margin="30,4" Fill="{StaticResource SecondaryText}" Opacity="0.1"/>

                        <!-- 右侧：技术栈 -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel LastChildFill="False" Margin="0,0,0,12">
                                <TextBlock Text="Developer" Style="{StaticResource SectionTitle}" DockPanel.Dock="Top"/>
                                <TextBlock Text="RADAMU" Style="{StaticResource ContentText}"/>
                            </DockPanel>

                            <DockPanel LastChildFill="False" Grid.Row="1">
                                <TextBlock Text="Framework" Style="{StaticResource SectionTitle}" DockPanel.Dock="Top"/>
                                <TextBlock Text=".NET 8.0 (Windows x64)" Style="{StaticResource ContentText}" FontFamily="Consolas"/>
                            </DockPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 3. 数据来源与链接 -->
                <Border Style="{StaticResource ModernCard}" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock Text="Data Provider" Style="{StaticResource SectionTitle}" Margin="0"/>
                            <TextBlock Text="Metadata provided by Bangumi.tv" FontSize="13" Foreground="{StaticResource SecondaryText}"/>
                        </StackPanel>

                        <!-- 按钮样式调整 -->
                        <ui:HyperlinkButton Grid.Column="1" 
                                            Content="Visit Bangumi" 
                                            NavigateUri="https://bangumi.tv/" 
                                            Icon="Globe24"
                                            Margin="0,0,8,0"/>
                    </Grid>
                </Border>

                <!-- 4. 开源致谢 (更紧凑的列表样式) -->
                <StackPanel Margin="4,20,0,10">
                    <TextBlock Text="Open Source Libraries" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource SecondaryText}" Margin="0,0,0,12"/>

                    <ItemsControl>
                        <ItemsControl.Items>
                            <sys:String>Newtonsoft.Json</sys:String>
                            <sys:String>WPF-UI (lepoco)</sys:String>
                            <sys:String>Microsoft-WindowsAPICodePack</sys:String>
                        </ItemsControl.Items>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- 条目样式：微小的背景块，看起来更整洁 -->
                                <Border Background="{StaticResource SubtleFill}" CornerRadius="6" Margin="0,0,0,8" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding}" Foreground="{StaticResource PrimaryText}" FontSize="13"/>
                                        <TextBlock Text="MIT / Ms-PL" Grid.Column="1" Foreground="{StaticResource SecondaryText}" FontSize="12" Opacity="0.6"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 底部版权 -->
                    <TextBlock Text="© 2026 RADAMU. All rights reserved." 
                               HorizontalAlignment="Center" 
                               Foreground="{StaticResource SecondaryText}" 
                               FontSize="12" Opacity="0.4" 
                               Margin="0,30,0,50"/>
                </StackPanel>

            </StackPanel>
        </ui:DynamicScrollViewer>
    </Grid>
</Page>