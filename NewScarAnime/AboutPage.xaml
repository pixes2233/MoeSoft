<Page x:Class="NewScarAnime.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:NewScarAnime"
      mc:Ignorable="d" 
      d:DesignHeight="768" d:DesignWidth="1366"
      Title="AboutPage">

    <Page.Resources>
        <!-- 统一配色和字号，便于后续调整（改为浅色主题） -->
        <LinearGradientBrush x:Key="PageBackground" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFFAFBFF" Offset="0.0"/>
            <GradientStop Color="#FFF0F4F8" Offset="1.0"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="CardBackground" Color="#CCFFFFFF"/>
        <SolidColorBrush x:Key="CardOverlay" Color="#0F000000"/>
        <SolidColorBrush x:Key="PrimaryText" Color="#1B1B1B"/>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
        </Style>
        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#222222"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <DropShadowEffect x:Key="CardShadow" Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.12"/>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackground}">

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 中央容器：限制宽度并在大屏幕上居中 -->
                <StackPanel Grid.Column="1" Width="700" HorizontalAlignment="Center" Margin="0,8,0,8">

                    <!-- 标题区：圆角图标 + 文本（图标添加阴影、圆角） -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,18">
                        <Border Width="100" Height="100" CornerRadius="18" Background="#10CCCCCC" 
                                VerticalAlignment="Center" HorizontalAlignment="Center" 
                                Effect="{StaticResource CardShadow}">
                            <Image Source="/Icon/icon.png" Stretch="UniformToFill" Margin="8" />
                        </Border>

                        <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock Text="About MoeSoft"
                                       FontSize="56"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryText}"
                                       VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="4" ShadowDepth="1" Opacity="0.25"/>
                                </TextBlock.Effect>
                            </TextBlock>

                            <TextBlock Text="A modern anime tracker designed to organize your shows and make your viewing experience more convenient."
                                       Style="{StaticResource BodyText}"
                                       FontSize="14"
                                       Margin="0,6,0,0"
                                       TextAlignment="Left"
                                       Width="520">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="3" ShadowDepth="1" Opacity="0.12"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- 信息卡片：浅色卡片，保留层次感 -->
                    <Border Background="{StaticResource CardBackground}" CornerRadius="12" Padding="20" Margin="0,0,0,18" Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <TextBlock Text="Version" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="1.4.3 Beta" Style="{StaticResource BodyText}" Margin="0,4,0,10"/>

                            <Separator Margin="0,6" Opacity="0.12"/>

                            <TextBlock Text="Author" Style="{StaticResource SectionHeader}" Margin="0,6,0,0"/>
                            <TextBlock Text="radamu" Style="{StaticResource BodyText}" Margin="0,4,0,10"/>

                            <Separator Margin="0,6" Opacity="0.12"/>

                            <TextBlock Text="Target Framework" Style="{StaticResource SectionHeader}" Margin="0,6,0,0"/>
                            <TextBlock Text=".NET 8.0 (Windows x64)" Style="{StaticResource BodyText}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 开源声明卡片：浅色风格 -->
                    <Border Background="{StaticResource CardBackground}" CornerRadius="12" Padding="20" Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <TextBlock Text="Open Source Credits"
                                       Style="{StaticResource SectionHeader}"
                                       Margin="0,0,0,12"/>

                            <!-- 每一行使用 StackPanel 结合小圆点保持原文不变 -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,2">
                                <Ellipse Width="6" Height="6" Fill="#888888" VerticalAlignment="Center" Margin="0,6,8,0"/>
                                <TextBlock Text="• Newtonsoft.Json © James Newton-King - MIT License" Style="{StaticResource BodyText}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,4,0,2">
                                <Ellipse Width="6" Height="6" Fill="#888888" VerticalAlignment="Center" Margin="0,6,8,0"/>
                                <TextBlock Text="• WPF-UI © lepoco - MIT License" Style="{StaticResource BodyText}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,4,0,2">
                                <Ellipse Width="6" Height="6" Fill="#888888" VerticalAlignment="Center" Margin="0,6,8,0"/>
                                <TextBlock Text="• WPF-UI.Abstractions © lepoco - MIT License" Style="{StaticResource BodyText}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,4,0,2">
                                <Ellipse Width="6" Height="6" Fill="#888888" VerticalAlignment="Center" Margin="0,6,8,0"/>
                                <TextBlock Text="• Microsoft-WindowsAPICodePack-Core © rpastitic, contre, dahall - Ms-PL" Style="{StaticResource BodyText}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Ellipse Width="6" Height="6" Fill="#888888" VerticalAlignment="Center" Margin="0,6,8,0"/>
                                <TextBlock Text="• Microsoft-WindowsAPICodePack-Shell © rpastitic, contre, dahall - Ms-PL" Style="{StaticResource BodyText}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- 左右占位以保证居中显示（在窄窗口上自动消失） -->
                <Border Grid.Column="0" Background="Transparent"/>
                <Border Grid.Column="2" Background="Transparent"/>

            </Grid>
        </ScrollViewer>
    </Grid>
</Page>