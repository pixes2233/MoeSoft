<Page x:Class="NewScarAnime.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:NewScarAnime"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="768" d:DesignWidth="1366"
      Title="HomePage">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid x:Name="Home" Background="{DynamicResource AcrylicBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="1"
           Width="32"
           Height="32"
           Background="Transparent"
           BorderThickness="0"
           CornerRadius="10"
           FocusVisualStyle="{x:Null}"
           Focusable="False"
           IsTabStop="False"
           Click="UpdateAnimeInfo"
           HorizontalAlignment="Right"
           VerticalAlignment="Center"
           Margin="0,0,8,0">

                <ui:Button.Style>
                    <Style TargetType="ui:Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>

                            <!-- Hover：轻微浮起感 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#14FFFFFF"/>
                            </Trigger>

                            <!-- Press：更实一点 -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#22FFFFFF"/>
                            </Trigger>

                        </Style.Triggers>
                    </Style>
                </ui:Button.Style>

                <ui:SymbolIcon Symbol="ArrowClockwise28"
                   FontSize="16"
                   Foreground="#E6F3F4F6"/>
            </ui:Button>

            <ProgressBar x:Name="ProgressBar" Grid.Column="1" IsIndeterminate="True" Visibility="Hidden" VerticalAlignment="Center"/>
        </Grid>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding Anime}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" ItemWidth="250" ItemHeight="330"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <ui:CardAction Width="200" Height="285" Margin="10" RenderTransformOrigin="0.5,0.5" Click="OpenAnimeInfo" Cursor="Hand">
                            <ui:CardAction.RenderTransform>
                                <ScaleTransform />
                            </ui:CardAction.RenderTransform>

                            <ui:CardAction.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="4" Opacity="0.3" />
                            </ui:CardAction.Effect>

                            <ui:CardAction.Style>
                                <Style TargetType="ui:CardAction">
                                    <!-- Template 保持不变 -->
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ui:CardAction">
                                                <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="25" 
                                SnapsToDevicePixels="True">
                                                    <Border.Clip>
                                                        <RectangleGeometry RadiusX="25" RadiusY="25" Rect="0,0,200,285"/>
                                                    </Border.Clip>
                                                    <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>

                                    <Style.Triggers>
                                        <!-- 1. 鼠标悬停 (MouseEnter): 丝滑放大 -->
                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <!-- 使用 CubicEase EaseOut：快速启动，平滑减速停止 -->
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <!-- 阴影也配合缓动 -->
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" To="20" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>

                                        <!-- 2. 鼠标离开 (MouseLeave): 平滑复位 -->
                                        <EventTrigger RoutedEvent="MouseLeave">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" To="10" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>

                                        <!-- 3. 鼠标按下 (PreviewMouseDown): 快速且有力的下沉 -->
                                        <EventTrigger RoutedEvent="PreviewMouseDown">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <!-- 按下动作要快 (0.08s)，使用 QuadraticEase 模拟更硬的撞击感 -->
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.95" Duration="0:0:0.08">
                                                        <DoubleAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.95" Duration="0:0:0.08">
                                                        <DoubleAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" To="5" Duration="0:0:0.08">
                                                        <DoubleAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>

                                        <!-- 4. 鼠标抬起 (PreviewMouseUp): 带轻微回弹的复位 -->
                                        <EventTrigger RoutedEvent="PreviewMouseUp">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <!-- 使用 BackEase 产生轻微的回弹效果（Overshoot），这会让松手的感觉非常Q弹 -->
                                                    <!-- Amplitude=0.3 代表回弹幅度，不要太大否则会晃 -->
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" To="20" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>

                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1"
                             Duration="0:0:0.2"/>

                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                             From="0.95" To="1"
                             Duration="0:0:0.2"/>

                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                             From="0.95" To="1"
                             Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>

                                    </Style.Triggers>
                                </Style>
                            </ui:CardAction.Style>

                            <ui:CardAction.Content>
                                <!-- 外部容器添加阴影效果（如果是WPF，建议套在DropShadowEffect中） -->
                                <Border ClipToBounds="True" CornerRadius="20">
                                    <Grid>
                                        <!-- 图片：稍微增加一点缩放动画的准备 -->
                                        <Image Source="{Binding AnimeCover}" Stretch="UniformToFill" />

                                        <!-- 顶层遮罩：底部暗化，防止白色背景图片导致标签看不清 -->
                                        <Border VerticalAlignment="Bottom" Height="60">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="Transparent" Offset="0"/>
                                                    <GradientStop Color="#66000000" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>

                                        <Border Margin="12"
        Padding="10,4"
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        CornerRadius="12"
        BorderThickness="1"
        BorderBrush="#44FFFFFF">

                                            <Border.Style>
                                                <Style TargetType="Border">

                                                    <!-- 默认隐藏 -->
                                                    <Setter Property="Visibility" Value="Collapsed"/>

                                                    <!-- 默认颜色（Current） -->
                                                    <Setter Property="Background" Value="#EEFFB7C5"/>

                                                    <Style.Triggers>

                                                        <!-- 本季度 -->
                                                        <DataTrigger Binding="{Binding SeasonType}"
                             Value="Current">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Setter Property="Background" Value="#EEFFB7C5"/>
                                                        </DataTrigger>

                                                        <!-- 下季度 -->
                                                        <DataTrigger Binding="{Binding SeasonType}"
                             Value="Next">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Setter Property="Background" Value="#FFF4D35E"/>
                                                        </DataTrigger>

                                                        <!-- 上季度 -->
                                                        <DataTrigger Binding="{Binding SeasonType}"
                             Value="Previous">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Setter Property="Background" Value="#FFA7C7E7"/>
                                                        </DataTrigger>

                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <StackPanel Orientation="Horizontal">

                                                <Ellipse Width="6"
                 Height="6"
                 Margin="0,0,6,0"
                 VerticalAlignment="Center">

                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#C71585"/>

                                                            <Style.Triggers>

                                                                <DataTrigger Binding="{Binding SeasonType}"
                                     Value="Next">
                                                                    <Setter Property="Fill" Value="#D4A017"/>
                                                                </DataTrigger>

                                                                <DataTrigger Binding="{Binding SeasonType}"
                                     Value="Previous">
                                                                    <Setter Property="Fill" Value="#4682B4"/>
                                                                </DataTrigger>

                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>

                                                </Ellipse>

                                                <TextBlock FontSize="11"
                   FontWeight="Bold"
                   VerticalAlignment="Center">

                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">

                                                            <Setter Property="Text" Value="本季度番剧"/>
                                                            <Setter Property="Foreground" Value="#C71585"/>

                                                            <Style.Triggers>

                                                                <DataTrigger Binding="{Binding SeasonType}"
                                     Value="Next">
                                                                    <Setter Property="Text" Value="下季度番剧"/>
                                                                    <Setter Property="Foreground" Value="#D4A017"/>
                                                                </DataTrigger>

                                                                <DataTrigger Binding="{Binding SeasonType}"
                                     Value="Previous">
                                                                    <Setter Property="Text" Value="上季度番剧"/>
                                                                    <Setter Property="Foreground" Value="#4682B4"/>
                                                                </DataTrigger>

                                                            </Style.Triggers>

                                                        </Style>
                                                    </TextBlock.Style>

                                                </TextBlock>

                                            </StackPanel>

                                        </Border>
                                    </Grid>
                                </Border>
                            </ui:CardAction.Content>
                        </ui:CardAction>

                        <TextBlock Grid.Row="1" Text="{Binding AnimeTitleCN}" FontSize="16" HorizontalAlignment="Center" Foreground="White"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Page>
