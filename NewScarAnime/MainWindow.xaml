<ui:FluentWindow x:Class="NewScarAnime.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NewScarAnime"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="MoeSoft" Height="768" Width="1366"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Acrylic"
        Background="{x:Null}"
        Loaded="MainWindow_Loaded">

    <!-- 资源：配色与样式 -->
    <ui:FluentWindow.Resources>
        <!-- 现代化标题栏：主为深色，带一点柔和的紫色点缀作现代感强调 -->
        <LinearGradientBrush x:Key="TitleBarBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#CC0E0F11" Offset="0.0"/>
            <GradientStop Color="#CC2B1330" Offset="0.55"/>
            <GradientStop Color="#CC0E0F11" Offset="1.0"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="TitleTextBrush" Color="#FFF3F4F6"/>
        <ImageBrush x:Key="TitleIconBrush" ImageSource="/Icon/icon.png"/>
        <!-- 悬停色保持低对比、带一点透光感，和标题栏配色协调 -->
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#22FFFFFF"/>
        <!-- 关闭按钮的更突出红色悬停 -->
        <SolidColorBrush x:Key="CloseButtonHoverBrush" Color="#44FF5252"/>

        <!-- 标题栏按钮：带投影效果（移除直接缩放以避免 XAML Setter 限制） -->
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4,2,4,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderThickness="0"
                                Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ButtonHoverBrush}"/>
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#22000000" BlurRadius="10" ShadowDepth="3"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#18000000" BlurRadius="6" ShadowDepth="1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 关闭按钮：基于 TitleBarButtonStyle，但悬停更红并更明显 -->
        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Foreground" Value="#FFF2F2F2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderThickness="0"
                                Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource CloseButtonHoverBrush}"/>
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#33FF5252" BlurRadius="12" ShadowDepth="2"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="bd" Property="Opacity" Value="0.98"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.92"/>
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#22FF5252" BlurRadius="6" ShadowDepth="1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 标题文本：添加轻微阴影与更圆润的视觉 -->
        <Style TargetType="TextBlock" x:Key="TitleTextStyle">
            <Setter Property="Foreground" Value="{StaticResource TitleTextBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#22000000" BlurRadius="6" ShadowDepth="1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ================= 终极美化版 Snackbar ================= -->
        <Style TargetType="{x:Type ui:Snackbar}">
            <!-- 1. 基础属性设置 -->
            <Setter Property="Background" Value="#E61E1E24"/>
            <!-- 稍微加深一点透明度，保证文字可读 -->
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MaxWidth" Value="600"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <!-- 增加一点下间距 -->

            <!-- 2. 关键：重写模板 (彻底摆脱官方默认样式的干扰) -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ui:Snackbar}">
                        <!-- 外层容器：负责动画位移 -->
                        <Grid x:Name="RootGrid" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <TranslateTransform Y="-30"/>
                                <!-- 初始位置：向上偏移30像素 -->
                            </Grid.RenderTransform>

                            <!-- 这里的 Opacity 初始设为 0，由动画控制变 1 -->
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Opacity" Value="0"/>
                                </Style>
                            </Grid.Style>

                            <!-- 卡片主体 -->
                            <Border Background="{TemplateBinding Background}"
                            BorderBrush="#33FFFFFF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16,12">

                                <!-- 悬浮阴影 -->
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" 
                                              BlurRadius="20" 
                                              ShadowDepth="4" 
                                              Opacity="0.4" 
                                              Direction="270"/>
                                </Border.Effect>

                                <!-- 内容布局 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- 图标 -->
                                        <ColumnDefinition Width="*"/>
                                        <!-- 文字 -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- 关闭按钮(可选) -->
                                    </Grid.ColumnDefinitions>

                                    <!-- 图标区域 -->
                                    <ContentPresenter Content="{TemplateBinding Icon}"
                                              Grid.Column="0"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,0"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>

                                    <!-- 文字区域 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <!-- 标题 -->
                                        <TextBlock Text="{TemplateBinding Title}"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Margin="0,0,0,2"/>
                                        <!-- 内容 -->
                                        <ContentPresenter Content="{TemplateBinding Content}"
                                                  Opacity="0.9"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- 3. 手写入场动画 (Loaded 事件触发) -->
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!-- 透明度：0 -> 1 -->
                                        <DoubleAnimation Storyboard.TargetName="RootGrid"
                                                 Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>

                                        <!-- 位移：-30 -> 0 (下滑效果) -->
                                        <DoubleAnimation Storyboard.TargetName="RootGrid"
                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 From="-30" To="0" Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <!-- ================= 标题栏 ================= -->
        <Grid Height="38"
      VerticalAlignment="Top"
      Background="Transparent"
      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
      SnapsToDevicePixels="True">

            <!-- 背景层 -->
            <Border CornerRadius="0,0,10,10"
            Background="#CC111318"
            BorderBrush="#22FFFFFF"
            BorderThickness="0,0,0,1"
            IsHitTestVisible="False">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                              ShadowDepth="0"
                              Color="#22000000"/>
                </Border.Effect>
            </Border>

            <!-- 左侧：Logo + 标题 -->
            <StackPanel Orientation="Horizontal"
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                IsHitTestVisible="False">

                <Border Width="22"
                Height="22"
                CornerRadius="6"
                Background="#22FFFFFF"
                BorderBrush="#33FFFFFF"
                BorderThickness="1">
                    <Image Source="/Icon/icon.png"
                   Stretch="Uniform"/>
                </Border>

                <TextBlock Text="MoeSoft"
                   Margin="8,0,0,0"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="#FFF3F4F6"
                   VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 右侧：窗口控制按钮 -->
            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,0,6,0"
                VerticalAlignment="Center">

                <Button Click="Minimize_Click"
                Width="34"
                Height="28"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                FocusVisualStyle="{x:Null}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                        Background="Transparent"
                                        CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1FFFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <TextBlock FontFamily="Segoe MDL2 Assets"
           Text="&#xE921;"
           FontSize="10"
           Foreground="#FFCCCCCC"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"/>
                </Button>

                <Button Click="Maximize_Click"
                Width="34"
                Height="28"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                FocusVisualStyle="{x:Null}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                        Background="Transparent"
                                        CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1FFFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <TextBlock x:Name="MaxIcon"
           FontFamily="Segoe MDL2 Assets"
           Text="&#xE922;"
           FontSize="10"
           Foreground="#FFCCCCCC"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"/>
                </Button>

                <Button Click="Close_Click"
                Width="34"
                Height="28"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                FocusVisualStyle="{x:Null}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                        Background="Transparent"
                                        CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#FFE04848"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#FFB93A3A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <TextBlock FontFamily="Segoe MDL2 Assets"
           Text="&#xE8BB;"
           FontSize="10"
           Foreground="White"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>


        <!-- 主内容区域 -->
        <Grid Margin="0,36,0,0">
            <!-- 导航栏 -->
            <ui:NavigationView x:Name="RootNavigation"
                               PaneDisplayMode="LeftFluent"
                               IsBackButtonVisible="Collapsed"
                               IsPaneOpen="False"
                               Background="Transparent"
                               Margin="8"
                               Cursor="">

                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem Tag="Home" 
                           TargetPageType="{x:Type local:HomePage}"
                           Content="番剧"
                           FontSize="12"
                           Foreground="Black"
                           Cursor="Hand">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="Home16" FontSize="24"/>
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>

                    <ui:NavigationViewItem Tag="Add"
                           TargetPageType="{x:Type local:BangumiSearch}"
                           Content="添加番剧"
                           FontSize="12"
                           Foreground="Black"
                           Cursor="Hand">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="AddSquareMultiple16" FontSize="24"/>
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>
                </ui:NavigationView.MenuItems>


                <ui:NavigationView.FooterMenuItems>
                    <ui:NavigationViewItem Tag="Update"
                            TargetPageType="{x:Type local:AboutPage}"
                            Content="关于"
                            FontSize="12"
                            Foreground="Black"
                            Cursor="Hand">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="Info16" FontSize="24"/>
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>
                </ui:NavigationView.FooterMenuItems>
            </ui:NavigationView>
        </Grid>

        <ui:SnackbarPresenter x:Name="RootSnackbar"
                      Grid.ZIndex="999"
                      VerticalAlignment="Top"
                      HorizontalAlignment="Center"
                      Margin="0,58,0,0">
        </ui:SnackbarPresenter>
        
        <ContentPresenter x:Name="RootContentDialogPresenter" Grid.RowSpan="99" />
    </Grid>
</ui:FluentWindow>
