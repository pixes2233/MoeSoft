<ui:FluentWindow x:Class="NewScarAnime.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NewScarAnime"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="MoeSoft" Height="768" Width="1366"
        ExtendsContentIntoTitleBar="True">

    <!-- 资源：配色与样式 -->
    <ui:FluentWindow.Resources>
        <LinearGradientBrush x:Key="TitleBarBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF1E1E2A" Offset="0.0"/>
            <GradientStop Color="#FF111014" Offset="1.0"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="TitleTextBrush" Color="#FFFFFFFF"/>
        <ImageBrush x:Key="TitleIconBrush" ImageSource="/Icon/icon.png"/>
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#33FFFFFF"/>
        <SolidColorBrush x:Key="CloseButtonHoverBrush" Color="#33FF5252"/>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4,2,4,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Foreground" Value="#FFF2F2F2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource CloseButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock" x:Key="TitleTextStyle">
            <Setter Property="Foreground" Value="{StaticResource TitleTextBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <!-- 自定义标题栏 -->
        <DockPanel VerticalAlignment="Top" Height="36" Background="{StaticResource TitleBarBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <!-- 左侧应用 Logo + 名称（也是拖动区域的一部分） -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="10,0,0,0" VerticalAlignment="Center">
                <Ellipse Width="28" Height="28" Fill="{StaticResource TitleIconBrush}" Margin="0,0,8,0"/>
                <TextBlock Text="MoeSoft" Style="{StaticResource TitleTextStyle}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 右侧窗口控制按钮 -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,6,0">
                <!-- 最小化 -->
                <Button Style="{StaticResource TitleBarButtonStyle}" Click="Minimize_Click" ToolTip="最小化" >
                    <TextBlock Text="—" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>

                <!-- 最大化/还原 -->
                <Button Style="{StaticResource TitleBarButtonStyle}" Click="Maximize_Click" ToolTip="最大化/还原">
                    <TextBlock Text="⬜" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>

                <!-- 关闭 -->
                <Button Style="{StaticResource CloseButtonStyle}" Click="Close_Click" ToolTip="关闭">
                    <TextBlock Text="✕" FontSize="14" FontWeight="Bold" Foreground="#FFFF5C5C" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
            </StackPanel>

            <!-- 可拖动的占位（在 DockPanel 中间，便于拖动窗口） -->
            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="8,0,0,0">
            </Grid>
        </DockPanel>

        <!-- 主内容区域 -->
        <Grid Margin="0,36,0,0">
            <!-- 导航栏 -->
            <ui:NavigationView x:Name="RootNavigation"
                               OpenPaneLength="75"
                               PaneDisplayMode="LeftFluent"
                               IsBackButtonVisible="Collapsed"
                               IsPaneOpen="False"
                               Background="{DynamicResource AcrylicBrushDark}"
                               Margin="5" Cursor="">

                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem Tag="Home" 
                           TargetPageType="{x:Type local:HomePage}"
                           Content="番剧"
                           FontSize="12"
                           Foreground="Black"
                           Cursor="Hand">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="Home16" FontSize="24"/>
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>

                    <ui:NavigationViewItem Tag="Add"
                           TargetPageType="{x:Type local:BangumiSearch}"
                           Content="添加番剧"
                           FontSize="12"
                           Foreground="Black"
                           Cursor="Hand">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="AddSquareMultiple16" FontSize="24"/>
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>
                </ui:NavigationView.MenuItems>


                <ui:NavigationView.FooterMenuItems>
                    <ui:NavigationViewItem Tag="Update"
                            TargetPageType="{x:Type local:AboutPage}"
                            Content="关于"
                            FontSize="12"
                            Foreground="Black"
                            Cursor="Hand">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="Info16" FontSize="24"/>
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>
                </ui:NavigationView.FooterMenuItems>
            </ui:NavigationView>
        </Grid>
    </Grid>
</ui:FluentWindow>
