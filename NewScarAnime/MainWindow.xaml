<ui:FluentWindow x:Class="NewScarAnime.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NewScarAnime"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="MoeSoft" Height="768" Width="1366"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Acrylic"
        Background="Transparent">

    <!-- 资源：配色与样式 -->
    <ui:FluentWindow.Resources>
        <!-- 现代化标题栏：主为深色，带一点柔和的紫色点缀作现代感强调 -->
        <LinearGradientBrush x:Key="TitleBarBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#CC0E0F11" Offset="0.0"/>
            <GradientStop Color="#CC2B1330" Offset="0.55"/>
            <GradientStop Color="#CC0E0F11" Offset="1.0"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="TitleTextBrush" Color="#FFF3F4F6"/>
        <ImageBrush x:Key="TitleIconBrush" ImageSource="/Icon/icon.png"/>
        <!-- 悬停色保持低对比、带一点透光感，和标题栏配色协调 -->
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#22FFFFFF"/>
        <!-- 关闭按钮的更突出红色悬停 -->
        <SolidColorBrush x:Key="CloseButtonHoverBrush" Color="#44FF5252"/>

        <!-- 标题栏按钮：带投影效果（移除直接缩放以避免 XAML Setter 限制） -->
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4,2,4,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderThickness="0"
                                Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ButtonHoverBrush}"/>
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#22000000" BlurRadius="10" ShadowDepth="3"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#18000000" BlurRadius="6" ShadowDepth="1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 关闭按钮：基于 TitleBarButtonStyle，但悬停更红并更明显 -->
        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Foreground" Value="#FFF2F2F2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderThickness="0"
                                Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource CloseButtonHoverBrush}"/>
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#33FF5252" BlurRadius="12" ShadowDepth="2"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="bd" Property="Opacity" Value="0.98"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.92"/>
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#22FF5252" BlurRadius="6" ShadowDepth="1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 标题文本：添加轻微阴影与更圆润的视觉 -->
        <Style TargetType="TextBlock" x:Key="TitleTextStyle">
            <Setter Property="Foreground" Value="{StaticResource TitleTextBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#22000000" BlurRadius="6" ShadowDepth="1"/>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <!-- ================= 标题栏 ================= -->
        <Grid Height="36"
      VerticalAlignment="Top"
      Background="Transparent"
      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

            <!-- 背景层 -->
            <Border Background="#AA0E0F11"
            BorderBrush="#22FFFFFF"
            BorderThickness="0,0,0,1"
            IsHitTestVisible="False">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="12"
                              ShadowDepth="0"
                              Color="#22000000"/>
                </Border.Effect>
            </Border>

            <!-- 左侧：Logo + 标题 -->
            <StackPanel Orientation="Horizontal"
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                IsHitTestVisible="False">

                <Border Width="22"
                Height="22"
                CornerRadius="6"
                Background="#FF8B5CF6">

                    <Image Source="/Icon/icon.png"
                   Stretch="Uniform"
                   Margin="3"/>
                </Border>

                <TextBlock Text="MoeSoft"
                   Margin="8,0,0,0"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="#FFF3F4F6"
                   VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 右侧：窗口控制按钮 -->
            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,0,4,0"
                VerticalAlignment="Center">

                <!-- 最小化 -->
                <Button Click="Minimize_Click"
                Width="32"
                Height="32"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand">
                    <TextBlock Text="—"
                       FontSize="14"
                       Foreground="#FFCCCCCC"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                </Button>

                <!-- 最大化 -->
                <Button Click="Maximize_Click"
                Width="32"
                Height="32"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand">
                    <TextBlock Text="□"
                       FontSize="12"
                       Foreground="#FFCCCCCC"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                </Button>

                <!-- 关闭 -->
                <Button Click="Close_Click"
                Width="32"
                Height="32"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand">
                    <TextBlock Text="✕"
                       FontSize="13"
                       Foreground="#FFDD5555"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>


        <!-- 主内容区域 -->
        <Grid Margin="0,36,0,0">
            <!-- 导航栏 -->
            <ui:NavigationView x:Name="RootNavigation"
                               PaneDisplayMode="LeftFluent"
                               IsBackButtonVisible="Collapsed"
                               IsPaneOpen="False"
                               Background="Transparent"
                               Margin="8"
                               Cursor="">

                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem Tag="Home" 
                           TargetPageType="{x:Type local:HomePage}"
                           Content="番剧"
                           FontSize="12"
                           Foreground="Black"
                           Cursor="Hand">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="Home16" FontSize="24"/>
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>

                    <ui:NavigationViewItem Tag="Add"
                           TargetPageType="{x:Type local:BangumiSearch}"
                           Content="添加番剧"
                           FontSize="12"
                           Foreground="Black"
                           Cursor="Hand">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="AddSquareMultiple16" FontSize="24"/>
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>
                </ui:NavigationView.MenuItems>


                <ui:NavigationView.FooterMenuItems>
                    <ui:NavigationViewItem Tag="Update"
                            TargetPageType="{x:Type local:AboutPage}"
                            Content="关于"
                            FontSize="12"
                            Foreground="Black"
                            Cursor="Hand">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="Info16" FontSize="24"/>
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>
                </ui:NavigationView.FooterMenuItems>
            </ui:NavigationView>
        </Grid>
    </Grid>
</ui:FluentWindow>
