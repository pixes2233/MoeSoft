<Page x:Class="NewScarAnime.AnimeInfoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:NewScarAnime"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="768" d:DesignWidth="1366"
      Title="AnimeInfoPage">

    <Page.Resources>
        <!-- 基础色彩 -->
        <SolidColorBrush x:Key="CardBackground" Color="#0FFFFFFF"/>
        <!-- 稍微降低不透明度，增强通透感 -->
        <SolidColorBrush x:Key="CardBorderBrush" Color="#1FFFFFFF"/>
        <!-- 样式：卡片容器 -->
        <Style x:Key="ModernCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="25"/>
            <!-- 稍微减小圆角，显得更现代硬朗 -->
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="10"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ui:Button
    Grid.Column="0"
    Appearance="Secondary"
    CornerRadius="18"
    Width="36"
    Height="36"
    Padding="0"
    Margin="10"
    HorizontalAlignment="Left"
    VerticalAlignment="Top"
    Click="BackToHome">

                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="ArrowLeft48" FontSize="18"/>
                </ui:Button.Icon>
            </ui:Button>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,10,0" Visibility="Visible">
                <ui:TextBlock x:Name="AutoLoadText" Text="正在自动获取 Bangumi 数据..." Foreground="#FFB8C0CC" FontSize="12.5" FontWeight="Normal" VerticalAlignment="Center" Margin="0,0,8,0" Opacity="0.9"/>
                <ui:ProgressRing x:Name="AutoProgress" IsIndeterminate="True" Visibility="Visible" Width="16" Height="16" Foreground="#FFB8C0CC"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
                <ui:DropDownButton
    Content="更多操作"
    Appearance="Secondary"
    CornerRadius="8"
    Padding="12,6"
    MinWidth="120">

                    <ui:DropDownButton.Flyout>
                        <ContextMenu
            Padding="6"
            BorderThickness="1"
            MinWidth="180">

                            <!-- 常规操作 -->
                            <MenuItem Header="Bangumi 网址" Click="OpenBangumiURL">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Symbol="Link48"/>
                                </MenuItem.Icon>
                            </MenuItem>

                            <MenuItem Header="刷新数据" Click="RefreshAnimeData">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Symbol="ArrowClockwise48"/>
                                </MenuItem.Icon>
                            </MenuItem>

                            <MenuItem Header="本地视频链接" Click="AddLocalLinkView">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Symbol="Link48"/>
                                </MenuItem.Icon>
                            </MenuItem>

                            <!-- 分隔（危险区） -->
                            <Separator Margin="6,8"/>

                            <MenuItem Header="删除本番剧" Click="DeleteAnime">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Symbol="Delete48"/>
                                </MenuItem.Icon>
                            </MenuItem>

                        </ContextMenu>
                    </ui:DropDownButton.Flyout>
                </ui:DropDownButton>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="362"/>
                <RowDefinition Height="8*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="AnimeCover" Grid.Row="0" Grid.Column="0" CornerRadius="25"  Height="342" Width="240" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
                <Border.Background>
                    <ImageBrush ImageSource="{Binding AnimeDetails.AnimeCover}" Stretch="UniformToFill"/>
                </Border.Background>
            </Border>

            <Grid Grid.Row="0" Grid.Column="1" Height="352" VerticalAlignment="Bottom">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="8*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding AnimeDetails.Title}" FontSize="36" FontWeight="Bold" Margin="10,10,10,0" TextWrapping="Wrap" VerticalAlignment="Top">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#696969" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding AnimeDetails.TitleCN}" FontSize="18" FontWeight="Bold" Margin="10,0,0,0" TextWrapping="Wrap" VerticalAlignment="Top">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#696969" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
                    </TextBlock.Effect>
                </TextBlock>
                <Border Grid.Row="2" Grid.Column="0" CornerRadius="25" Margin="10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding AnimeDetails.Summary}" FontSize="15" TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Grid Grid.Row="1" Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Width="240" Style="{StaticResource ModernCard}" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="{Binding AnimeDetails.BeginDate}" FontSize="15" HorizontalAlignment="Left" TextWrapping="Wrap" Margin="5"/>
                        <TextBlock Grid.Row="1" Text="{Binding AnimeDetails.TotalEP}" FontSize="15" HorizontalAlignment="Left" TextWrapping="Wrap" Margin="5"/>
                        <TextBlock Grid.Row="2" Text="{Binding AnimeDetails.Update}" FontSize="15" HorizontalAlignment="Left" TextWrapping="Wrap" Margin="5"/>
                        <TextBlock Grid.Row="3" Text="{Binding AnimeDetails.Director}" FontSize="15" HorizontalAlignment="Left" TextWrapping="Wrap" Margin="5"/>
                        <TextBlock Grid.Row="4" Text="{Binding AnimeDetails.Writer}" FontSize="15" HorizontalAlignment="Left" TextWrapping="Wrap" Margin="5"/>
                        <TextBlock Grid.Row="5" Text="{Binding AnimeDetails.Studio}" FontSize="15" HorizontalAlignment="Left" TextWrapping="Wrap" Margin="5"/>
                        <TextBlock Grid.Row="6" Text="{Binding AnimeDetails.NowEP}" FontSize="15" HorizontalAlignment="Left" TextWrapping="Wrap" Margin="5"/>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="8*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Column="0" Grid.Row="0" Style="{StaticResource ModernCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <ui:TextBlock Grid.Row="0" x:Name="LocalLinkError" Text="你尚未添加视频地址≡(▔﹏▔)≡" Visibility="Collapsed" HorizontalAlignment="Center"/>

                        <ItemsControl ItemsSource="{Binding Files}" Margin="5">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <ui:CardAction Height="50" HorizontalAlignment="Stretch" Margin="0,0,0,15" Content="{Binding Name}" VerticalContentAlignment="Center" FontSize="15" Click="CardAction_Click">
                                            <ui:CardAction.Template>
                                                <ControlTemplate TargetType="{x:Type ui:CardAction}">
                                                    <Border x:Name="CardBorder"
                                                            Background="White"
                                                            CornerRadius="20"
                                                            Padding="7">
                                                        <ContentPresenter
                                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                            Content="{TemplateBinding Content}"
                                                            ContentTemplate="{TemplateBinding ContentTemplate}" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <!-- 鼠标悬停触发 -->
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="CardBorder" Property="Background" Value="SteelBlue"/>
                                                        </Trigger>
                                                        <!-- 按下触发 -->
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="CardBorder" Property="Background" Value="DarkBlue"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </ui:CardAction.Template>

                                            <ui:CardAction.Style>
                                                <Style TargetType="ui:CardAction">
                                                    <Setter Property="Foreground" Value="Black"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LastWatchStatus}" Value="true">
                                                            <Setter Property="Foreground" Value="LightPink"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:CardAction.Style>
                                        </ui:CardAction>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
