<Application x:Class="NewScarAnime.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NewScarAnime"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- 1. 外部资源合并 (WPF UI 主题) 必须放在最前面 -->
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- 2. 自定义资源 (覆盖默认颜色) 必须放在 MergedDictionaries 之后 -->
            <!-- 这样你的设置才能覆盖 WPF UI 的默认设置 -->
            <SolidColorBrush x:Key="WPFUI.Theme.Accent.Primary" Color="#007ACC" />
            <SolidColorBrush x:Key="WPFUI.Theme.Accent.Secondary" Color="#1E90FF" />
            <SolidColorBrush x:Key="WPFUI.Theme.Accent.Tertiary" Color="#4682B4" />

            <!-- 3. 全局样式设置 -->
            <Style TargetType="Control">
                <Setter Property="FontFamily" Value="/ScarAnime;component/Fonts/NotoSans-VariableFont_wdth,wght.ttf#Noto Sans SC"/>
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="/ScarAnime;component/Fonts/NotoSans-VariableFont_wdth,wght.ttf#Noto Sans SC"/>
            </Style>

            <Style TargetType="ui:TextBlock">
                <Setter Property="FontFamily" Value="/ScarAnime;component/Fonts/NotoSans-VariableFont_wdth,wght.ttf#Noto Sans SC"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>