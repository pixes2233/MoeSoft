<Page x:Class="NewScarAnime.BangumiSearch"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:NewScarAnime"
      mc:Ignorable="d" 
      d:DesignHeight="768" d:DesignWidth="1366"
      Title="BangumiSearch">

    <Grid>
        <StackPanel Orientation="Vertical">
            <TextBlock Text="Bangumi搜索番剧 Beta版" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="20,10,0,10"
                       Foreground="#FFB6C1">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1"/>
                </TextBlock.Effect>
            </TextBlock>

            <ui:TextBlock Text="数据来源:https://bangumi.tv/ 目前该功能处于Beta测试版 搜索结果只显示第一页 点击添加后要一段时间才可生效" HorizontalAlignment="Center">
            </ui:TextBlock>

            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <ui:AutoSuggestBox x:Name="AnimeName" Margin="10" Width="300" KeyDown="AnimeNameSearch" PlaceholderText="输入番剧名称并回车搜索"/>
                <ui:TextBlock x:Name="SearchResultCount" Text="遇到错误惹(￣﹏￣；)" Margin="10" VerticalAlignment="Center" Visibility="Hidden"/>
            </StackPanel>

            <ui:ProgressRing x:Name="SearchStatus" IsIndeterminate="True" Visibility="Collapsed" HorizontalAlignment="Center"/>

            <ItemsControl ItemsSource="{Binding AnimeResult}" HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="10" HorizontalAlignment="Center" Width="800" Height="300" CornerRadius="25" Background="#80FFDBE5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ui:Image Grid.Column="0" Height="260" VerticalAlignment="Center" Stretch="Uniform" Margin="20" CornerRadius="25">
                                    <ui:Image.Source>
                                        <BitmapImage UriSource="{Binding image}" CreateOptions="IgnoreImageCache" CacheOption="OnLoad"/>
                                    </ui:Image.Source>

                                    <ui:Image.Effect>
                                        <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="Black" Opacity="0.8"/>
                                    </ui:Image.Effect>
                                </ui:Image>
                                <StackPanel Grid.Column="1" Orientation="Vertical">
                                    <ui:TextBlock Text="{Binding title}" FontSize="25" FontWeight="Bold" Margin="10" Foreground="Black" HorizontalAlignment="Left"/>
                                    <ui:Button Margin="10" Content="添加番剧" Appearance="Primary" FontSize="14" Click="AddAnime" VerticalAlignment="Top" BorderBrush="Transparent" CornerRadius="15"/>
                                    <ui:Button Margin="10" Content="打开链接" Appearance="Primary" FontSize="14" Click="OpenLink" VerticalAlignment="Top" BorderBrush="Transparent" CornerRadius="15"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</Page>
